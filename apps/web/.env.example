# Deepgram (live TTS / STT)
DEEPGRAM_API_KEY=
DEEPGRAM_ENV=development

# STT keyword biasing (client-side, baked into the Next.js bundle at build time).
# When enabled, each phrase's target words are forwarded to Deepgram via the
# `keywords` param with a :2 boost to help the ASR recover short words like
# "algo". Set to `false` / `0` / `off` / `no` to disable for A/B comparison.
# Defaults to enabled when unset.
NEXT_PUBLIC_STT_KEYWORDS_ENABLED=true

# Murf TTS (optional alternate provider)
MURF_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# ── S3 audio delivery (presigned URLs via GET /api/audio) ────────────────────
# IAM credentials with s3:GetObject on arn:aws:s3:::BUCKET/audio-content/*
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET_NAME=ai-spanish

# S3 key prefix written by tts-batch (default: audio-content)
AUDIO_CONTENT_PREFIX=audio-content

# Optional lesson subfolder under AUDIO_CONTENT_PREFIX (e.g. lesson1).
# Must match the --lesson / S3_LESSON used during tts-batch upload.
# Leave blank for no subfolder (keys will be audio-content/audio/{jobId}.mp3).
S3_LESSON=lesson1

# Feature flag: forward per-phrase `keywords` to Deepgram's live transcription
# for ASR biasing. Defaults to enabled when unset.
NEXT_PUBLIC_STT_KEYWORDS_ENABLED=true

# Supabase (Auth) — Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=