.env
.env.local
.env.development
.env.production
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# ESLint
.eslintcache

# Certificates / keys
*.pem

# OS
.DS_Store

# Local editor / agent config
**/.claude/settings.local.json
.vscode
