# See https://help.github.com/articles/ignoring-files/

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/
build/

# Testing
coverage/

# Vercel
.vercel

# Turborepo (cache if tasks are run scoped to this app)
