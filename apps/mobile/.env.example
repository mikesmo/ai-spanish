# Base URL of the Next.js web app. Required for:
#   - /api/transcript (lesson JSON)
#   - /api/package-audio (UX mp3 clips from @ai-spanish/assets)
#   - /api/authenticate (short-lived Deepgram listen keys for speech-to-text)
#   - /api/text-to-speech (pronunciation audio)
# Use your machine's LAN IP — localhost does not work on physical devices or the Android emulator.
# Run `ipconfig getifaddr en0` to find your LAN IP. See README.md for full setup instructions.
EXPO_PUBLIC_WEB_ORIGIN=http://<your-lan-ip>:3000

# Same Supabase project as the web app (mobile sends Bearer tokens to Next API routes).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
