# Copy to `.env.scripts` at the monorepo root (gitignored).
# Shared by: npm run push:transcripts, npm run tts:batch, npm run migrate:lesson1

# --- Supabase (push-transcripts, migrate-lesson-weights Supabase mode, tts-batch transcript-from-DB)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: default lesson when loading transcript from DB without --transcript-lesson (tts-batch / migrate-lesson)
# TRANSCRIPT_LESSON_ID=1

# --- push-transcripts
# (uses only NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above)

# --- tts-batch: transcript file alternative to Supabase
# TRANSCRIPT_INPUT=

# --- tts-batch: Deepgram TTS / STT (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Optional Deepgram Aura voice ids (defaults in code if unset)
# TTS_DEEPGRAM_VOICE_EN=aura-2-pandora-en
# TTS_DEEPGRAM_VOICE_ES=aura-2-agustina-es

# --- tts-batch: S3 upload (omit when using --local-only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# S3 key prefix (single segment); default in code: audio-content
AUDIO_CONTENT_PREFIX=

# Optional folder under prefix (overridden by --lesson)
S3_LESSON=

# --- Optional verification thresholds (tts-batch --verify-* )
# TTS_VERIFY_LOUDNESS_MIN_MAX_DB=-30
# TTS_VERIFY_LOUDNESS_MIN_MEAN_DB=-40
