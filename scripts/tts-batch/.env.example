# Get your API key from https://console.deepgram.com
DEEPGRAM_API_KEY=

# Path to the transcript JSON (relative to monorepo root or absolute).
# Default: apps/web/public/transcript.json. Overridden by --input.
TRANSCRIPT_INPUT=apps/web/public/transcript.json

# Only required when NOT using --local-only
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# S3 object key prefix (single segment). Default in code: audio-content
# Results in keys like: {prefix}/[{S3_LESSON}/]audio/{id}.mp3 and .../manifest.json
AUDIO_CONTENT_PREFIX=

# Optional lesson folder under the prefix (overridden by --lesson)
S3_LESSON=
