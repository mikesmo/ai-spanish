# Get your API key from https://console.deepgram.com
DEEPGRAM_API_KEY=

# Optional Deepgram Aura voice model ids for batch TTS (defaults shown).
# TTS_DEEPGRAM_VOICE_EN=aura-2-pandora-en
# TTS_DEEPGRAM_VOICE_ES=aura-2-agustina-es

# Path to the transcript JSON (relative to monorepo root or absolute). Used when --input / TRANSCRIPT_INPUT is set.
# Alternative: omit file input and use TRANSCRIPT_LESSON_ID + Supabase (see below).
# TRANSCRIPT_INPUT=

# Load transcript from Supabase `lesson_transcripts` (lesson id 1 or 2) when no TRANSCRIPT_INPUT/--input.
# Requires NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY (same as apps/web server).
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# TRANSCRIPT_LESSON_ID=1

# Only required when NOT using --local-only
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# S3 object key prefix (single segment). Default in code: audio-content
# Results in keys like: {prefix}/[{S3_LESSON}/]audio/{id}.mp3 and .../manifest.json
AUDIO_CONTENT_PREFIX=

# Optional lesson folder under the prefix (overridden by --lesson)
S3_LESSON=
